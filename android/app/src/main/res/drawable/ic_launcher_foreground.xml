<?xml version="1.0" encoding="utf-8"?>
<!--
  Apex Lines 앱 아이콘 전경.

  사용자 제공 PNG (drawable-xxxhdpi/ic_launcher_image.png, 432x432) 를 그대로 어댑티브
  아이콘 foreground 로 사용. 시스템이 적용하는 마스크(원/스쿼클/티어드롭)에 따라
  가장자리(검정 영역) 가 잘리고, 중앙의 차 + 시안 헤드라이트 + 앰버 글로우는 그대로 보임.

  PNG 가 이미 1:1 정사각이고 차 콘텐츠가 안전 영역(중앙 66%) 안에 들어 있어 별도 inset
  필요 없음.
-->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@drawable/ic_launcher_image"
    android:gravity="center"
    android:antialias="true"
    android:filter="true" />

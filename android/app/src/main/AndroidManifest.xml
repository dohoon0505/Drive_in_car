<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 네트워크 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 위치 (Race tracking) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- 포어그라운드 위치 서비스 (Race in progress) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 배터리 최적화 면제 (선택, 사용자가 허용해야 효과) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".DriveInCarApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DriveInCar"
        android:usesCleartextTraffic="false"
        tools:targetApi="34">

        <!-- 단일 액티비티 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.DriveInCar.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Race tracking foreground service -->
        <service
            android:name=".service.RaceTrackingService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Naver Maps SDK 인증.
             VPC > Maps > Application 에서 발급한 NCP API Key ID 를 NCP_KEY_ID 메타에 넣는다.
             구 AI Service Maps 의 CLIENT_ID 와 다른 키 이름이라 혼동 주의 — VPC Maps 는 반드시 NCP_KEY_ID.
             secrets-gradle-plugin 이 local.properties 의 NAVER_MAP_CLIENT_ID 값을 여기 주입.
             SDK 는 패키지명 com.driveincar 가 NCP Console 에 등록되어 있는지도 검증한다. -->
        <meta-data
            android:name="com.naver.maps.map.NCP_KEY_ID"
            android:value="${NAVER_MAP_CLIENT_ID}" />

    </application>
</manifest>
